[gd_resource type="Resource" script_class="RangeSetting" format=3 uid="uid://cg3dwil6gki2"]

[ext_resource type="Script" uid="uid://bvn8up4ojt8t1" path="res://addons/fusionex/settings/resource/range_setting.gd" id="1_oqbox"]

[sub_resource type="GDScript" id="GDScript_oqbox"]
script/source = "static func apply_setting(value: Variant) -> void:
	AudioServer.set_bus_volume_linear(AudioServer.get_bus_index(&\"Master\"), value)
"

